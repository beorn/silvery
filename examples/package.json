{
  "name": "@silvery/examples",
  "version": "0.19.2",
  "description": "Example apps and component demos for silvery — npx @silvery/examples <name>",
  "license": "MIT",
  "author": "Bjørn Stabell <bjorn@stabell.org>",
  "repository": {
    "type": "git",
    "url": "https://github.com/beorn/silvery.git",
    "directory": "examples"
  },
  "bin": {
    "silvery-examples": "./bin/cli.ts"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": "./bin/cli.ts"
  },
  "publishConfig": {
    "access": "public",
    "bin": {
      "silvery-examples": "./dist/cli.mjs"
    },
    "exports": {
      ".": {
        "types": "./dist/cli.d.mts",
        "import": "./dist/cli.mjs"
      }
    }
  },
  "dependencies": {
    "loggily": "^0.6.0",
    "react": "^19.0.0",
    "silvery": "0.18.2"
  },
  "tsdown": {
    "clean": true,
    "dts": false,
    "entry": "bin/cli.ts",
    "external": [
      "silvery",
      "silvery/*",
      "react",
      "loggily"
    ],
    "format": "esm"
  },
  "engines": {
    "bun": ">=1.0",
    "node": ">=18.0.0"
  },
  "private": true
}
