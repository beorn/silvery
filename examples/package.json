{
  "name": "@silvery/examples",
  "version": "0.5.6",
  "description": "Example apps and component demos for silvery — npx @silvery/examples <name>",
  "license": "MIT",
  "author": "Bjørn Stabell <bjorn@stabell.org>",
  "repository": {
    "type": "git",
    "url": "https://github.com/beorn/silvery.git",
    "directory": "examples"
  },
  "type": "module",
  "bin": {
    "silvery-examples": "./bin/cli.ts"
  },
  "files": [
    "dist",
    "components",
    "apps",
    "layout",
    "runtime",
    "inline",
    "kitty",
    "_banner.tsx"
  ],
  "exports": {
    ".": "./bin/cli.ts"
  },
  "publishConfig": {
    "access": "public",
    "bin": {
      "silvery-examples": "./dist/cli.mjs"
    },
    "exports": {
      ".": {
        "types": "./dist/cli.d.mts",
        "import": "./dist/cli.mjs"
      }
    }
  },
  "tsdown": {
    "entry": "bin/cli.ts",
    "format": "esm",
    "dts": true,
    "clean": true
  },
  "dependencies": {
    "silvery": "0.17.2"
  },
  "engines": {
    "bun": ">=1.0",
    "node": ">=18.0.0"
  }
}
