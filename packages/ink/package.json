{
  "name": "@silvery/ink",
  "version": "0.20.0",
  "private": true,
  "description": "Ink and Chalk API compatibility layer (not published separately)",
  "license": "MIT",
  "author": "Bjørn Stabell <bjorn@stabell.org>",
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./*": "./src/*.ts"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.mts",
        "import": "./dist/index.mjs"
      },
      "./chalk": {
        "types": "./dist/chalk.d.mts",
        "import": "./dist/chalk.mjs"
      },
      "./ink": {
        "types": "./dist/ink.d.mts",
        "import": "./dist/ink.mjs"
      },
      "./with-ink": {
        "types": "./dist/with-ink.d.mts",
        "import": "./dist/with-ink.mjs"
      },
      "./with-ink-cursor": {
        "types": "./dist/with-ink-cursor.d.mts",
        "import": "./dist/with-ink-cursor.mjs"
      },
      "./with-ink-focus": {
        "types": "./dist/with-ink-focus.d.mts",
        "import": "./dist/with-ink-focus.mjs"
      }
    }
  },
  "scripts": {
    "build": "tsdown"
  },
  "dependencies": {
    "@silvery/ag-react": "0.20.0",
    "@silvery/ag-term": "0.20.0",
    "@silvery/ansi": "0.20.0"
  },
  "tsdown": {
    "clean": true,
    "dts": true,
    "entry": [
      "src/index.ts",
      "src/chalk.ts",
      "src/ink.ts",
      "src/with-ink.ts",
      "src/with-ink-cursor.ts",
      "src/with-ink-focus.ts"
    ],
    "format": "esm"
  }
}
