{
  "name": "@silvery/ink",
  "version": "0.17.3",
  "description": "Ink and Chalk API compatibility layer (not published separately)",
  "license": "MIT",
  "author": "Bjørn Stabell <bjorn@stabell.org>",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.mts",
        "import": "./dist/index.mjs"
      }
    }
  },
  "dependencies": {
    "@silvery/ag-react": "0.17.3",
    "@silvery/ag-term": "0.17.3",
    "@silvery/ansi": "0.17.3"
  },
  "tsdown": {
    "entry": "src/index.ts",
    "format": "esm",
    "dts": true,
    "clean": true
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown"
  },
  "private": true
}
