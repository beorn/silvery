{
  "name": "@silvery/ag",
  "version": "0.17.3",
  "private": true,
  "description": "Core types and infrastructure for silvery (internal — use silvery instead)",
  "license": "MIT",
  "author": "Bjørn Stabell <bjorn@stabell.org>",
  "repository": {
    "type": "git",
    "url": "https://github.com/beorn/silvery.git",
    "directory": "packages/ag"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./*": "./src/*.ts"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.mts",
        "import": "./dist/index.mjs"
      },
      "./dirty-tracking": {
        "types": "./dist/dirty-tracking.d.mts",
        "import": "./dist/dirty-tracking.mjs"
      },
      "./drag-event-types": {
        "types": "./dist/drag-event-types.d.mts",
        "import": "./dist/drag-event-types.mjs"
      },
      "./epoch": {
        "types": "./dist/epoch.d.mts",
        "import": "./dist/epoch.mjs"
      },
      "./focus-events": {
        "types": "./dist/focus-events.d.mts",
        "import": "./dist/focus-events.mjs"
      },
      "./focus-manager": {
        "types": "./dist/focus-manager.d.mts",
        "import": "./dist/focus-manager.mjs"
      },
      "./focus-queries": {
        "types": "./dist/focus-queries.d.mts",
        "import": "./dist/focus-queries.mjs"
      },
      "./interactive-signals": {
        "types": "./dist/interactive-signals.d.mts",
        "import": "./dist/interactive-signals.mjs"
      },
      "./keys": {
        "types": "./dist/keys.d.mts",
        "import": "./dist/keys.mjs"
      },
      "./layout-types": {
        "types": "./dist/layout-types.d.mts",
        "import": "./dist/layout-types.mjs"
      },
      "./mouse-event-types": {
        "types": "./dist/mouse-event-types.d.mts",
        "import": "./dist/mouse-event-types.mjs"
      },
      "./text-frame": {
        "types": "./dist/text-frame.d.mts",
        "import": "./dist/text-frame.mjs"
      },
      "./tree-utils": {
        "types": "./dist/tree-utils.d.mts",
        "import": "./dist/tree-utils.mjs"
      },
      "./rect-signals": {
        "types": "./dist/rect-signals.d.mts",
        "import": "./dist/rect-signals.mjs"
      },
      "./node-signals": {
        "types": "./dist/node-signals.d.mts",
        "import": "./dist/node-signals.mjs"
      },
      "./types": {
        "types": "./dist/types.d.mts",
        "import": "./dist/types.mjs"
      }
    }
  },
  "scripts": {
    "build": "tsdown"
  },
  "dependencies": {
    "@silvery/signals": "0.17.3"
  },
  "tsdown": {
    "clean": true,
    "dts": true,
    "entry": [
      "src/index.ts",
      "src/dirty-tracking.ts",
      "src/drag-event-types.ts",
      "src/epoch.ts",
      "src/focus-events.ts",
      "src/focus-manager.ts",
      "src/focus-queries.ts",
      "src/interactive-signals.ts",
      "src/keys.ts",
      "src/layout-types.ts",
      "src/mouse-event-types.ts",
      "src/text-frame.ts",
      "src/tree-utils.ts",
      "src/rect-signals.ts",
      "src/node-signals.ts",
      "src/types.ts"
    ],
    "format": "esm"
  }
}
