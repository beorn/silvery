    },
    "./types": {
      "types": "./src/types.ts",
      "import": "./src/types.ts"
    },
    "./keys": {
      "types": "./src/keys.ts",
      "import": "./src/keys.ts"
    },
    "./focus-manager": {
      "types": "./src/focus-manager.ts",
      "import": "./src/focus-manager.ts"
    },
    "./focus-events": {
      "types": "./src/focus-events.ts",
      "import": "./src/focus-events.ts"
    },
    "./tree-utils": {
      "types": "./src/tree-utils.ts",
      "import": "./src/tree-utils.ts"
    },
    "./*": "./src/*.ts"
  },
  "dependencies": {
    "@silvery/ag-term": "workspace:*",
    "@silvery/create": "workspace:*"
  }
