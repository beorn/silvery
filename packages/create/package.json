{
  "name": "@silvery/create",
  "version": "0.5.3",
  "description": "App composition and state management for silvery",
  "license": "MIT",
  "author": "Bjørn Stabell <bjorn@stabell.org>",
  "repository": {
    "type": "git",
    "url": "https://github.com/beorn/silvery.git",
    "directory": "packages/create"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.mts",
        "import": "./dist/index.mjs"
      }
    }
  },
  "dependencies": {
    "@silvery/ag": "0.5.2",
    "@silvery/ag-react": "0.5.2",
    "@silvery/ag-term": "0.5.2",
    "@silvery/commands": "0.5.2",
    "@silvery/headless": "0.5.1",
    "@silvery/ink": "0.5.1",
    "@silvery/test": "0.5.3",
    "alien-signals": "^3.1.2"
  },
  "engines": {
    "bun": ">=1.0",
    "node": ">=18.0.0"
  },
  "tsdown": {
    "entry": "src/index.ts",
    "format": "esm",
    "dts": true,
    "clean": true
  },
  "scripts": {
    "build": "tsdown"
  }
}
