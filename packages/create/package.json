{
  "name": "@silvery/create",
  "version": "0.5.0",
  "description": "App composition and state management for silvery",
  "license": "MIT",
  "author": "Bjørn Stabell <bjorn@stabell.org>",
  "repository": {
    "type": "git",
    "url": "https://github.com/beorn/silvery.git",
    "directory": "packages/create"
  },
  "files": [
    "src"
  ],
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./core": {
      "types": "./src/core/index.ts",
      "import": "./src/core/index.ts"
    },
    "./store": {
      "types": "./src/store/index.ts",
      "import": "./src/store/index.ts"
    },
    "./tea": {
      "types": "./src/tea/index.ts",
      "import": "./src/tea/index.ts"
    },
    "./streams": {
      "types": "./src/streams/index.ts",
      "import": "./src/streams/index.ts"
    },
    "./plugins": {
      "types": "./src/plugins.ts",
      "import": "./src/plugins.ts"
    },
    "./create-app": {
      "types": "./src/create-app.tsx",
      "import": "./src/create-app.tsx"
    },
    "./*": "./src/*.ts"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@silvery/ag": "0.5.0",
    "@silvery/ag-react": "0.5.0",
    "@silvery/ag-term": "0.5.0",
    "@silvery/commands": "0.5.0",
    "@silvery/headless": "0.5.0",
    "@silvery/ink": "0.5.0",
    "@silvery/test": "0.5.0",
    "alien-signals": "^3.1.2"
  }
}
