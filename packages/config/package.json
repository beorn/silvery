{
  "name": "@silvery/config",
  "version": "0.21.0",
  "description": "Generic config-tree + named-registry primitives with string ↔ object projection",
  "keywords": [
    "config",
    "connection-string",
    "preset",
    "registry",
    "silvery",
    "yaml"
  ],
  "license": "MIT",
  "author": "Bjørn Stabell <bjorn@stabell.org>",
  "repository": {
    "type": "git",
    "url": "https://github.com/beorn/silvery.git",
    "directory": "packages/config"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": "./src/index.ts",
    "./commander": "./src/commander.ts"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.mts",
        "import": "./dist/index.mjs"
      },
      "./commander": {
        "types": "./dist/commander.d.mts",
        "import": "./dist/commander.mjs"
      }
    }
  },
  "scripts": {
    "build": "tsdown"
  },
  "dependencies": {
    "cosmiconfig": "^9.0.1",
    "yaml": ">=2.0.0",
    "alien-signals": "^3.1.2"
  },
  "peerDependencies": {
    "@silvery/commander": "0.21.0",
    "zod": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "@silvery/commander": {
      "optional": true
    }
  },
  "tsdown": {
    "clean": true,
    "dts": true,
    "entry": [
      "src/index.ts",
      "src/commander.ts"
    ],
    "external": [
      "@silvery/commander",
      "alien-signals",
      "commander",
      "cosmiconfig",
      "yaml",
      "zod"
    ],
    "format": "esm"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
