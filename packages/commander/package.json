{
  "name": "@silvery/commander",
  "version": "0.17.5",
  "description": "Colorized Commander.js help output using ANSI escape codes",
  "keywords": [
    "ansi",
    "cli",
    "color",
    "commander",
    "help"
  ],
  "license": "MIT",
  "author": "Bjørn Stabell <bjorn@stabell.org>",
  "repository": {
    "type": "git",
    "url": "https://github.com/beorn/silvery.git",
    "directory": "packages/commander"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": "./src/index.ts"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.mts",
        "import": "./dist/index.mjs"
      }
    }
  },
  "dependencies": {
    "@silvery/ansi": "0.17.3",
    "commander": ">=13.0.0",
    "zod": ">=3.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "tsdown": {
    "entry": "src/index.ts",
    "format": "esm",
    "dts": true,
    "clean": true,
    "external": [
      "commander",
      "zod",
      "@silvery/ansi"
    ]
  },
  "scripts": {
    "build": "tsdown"
  }
}
