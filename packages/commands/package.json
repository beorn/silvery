{
  "name": "@silvery/commands",
  "version": "0.19.2",
  "private": true,
  "description": "Command registry, keymaps, and invocation for silvery apps",
  "license": "MIT",
  "author": "Bjørn Stabell <bjorn@stabell.org>",
  "repository": {
    "type": "git",
    "url": "https://github.com/beorn/silvery.git",
    "directory": "packages/commands"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./*": "./src/*.ts"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.mts",
        "import": "./dist/index.mjs"
      },
      "./create-command-registry": {
        "types": "./dist/create-command-registry.d.mts",
        "import": "./dist/create-command-registry.mjs"
      },
      "./keys": {
        "types": "./dist/keys.d.mts",
        "import": "./dist/keys.mjs"
      },
      "./with-commands": {
        "types": "./dist/with-commands.d.mts",
        "import": "./dist/with-commands.mjs"
      },
      "./with-keybindings": {
        "types": "./dist/with-keybindings.d.mts",
        "import": "./dist/with-keybindings.mjs"
      }
    }
  },
  "scripts": {
    "build": "tsdown"
  },
  "dependencies": {},
  "tsdown": {
    "clean": true,
    "dts": true,
    "entry": [
      "src/index.ts",
      "src/create-command-registry.ts",
      "src/keys.ts",
      "src/with-commands.ts",
      "src/with-keybindings.ts"
    ],
    "format": "esm"
  }
}
