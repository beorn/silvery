{
  "name": "@silvery/commands",
  "version": "0.17.3",
  "description": "Command registry, keymaps, and invocation for silvery apps",
  "license": "MIT",
  "author": "Bjørn Stabell <bjorn@stabell.org>",
  "repository": {
    "type": "git",
    "url": "https://github.com/beorn/silvery.git",
    "directory": "packages/commands"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.mts",
        "import": "./dist/index.mjs"
      }
    }
  },
  "dependencies": {},
  "tsdown": {
    "entry": "src/index.ts",
    "format": "esm",
    "dts": true,
    "clean": true
  },
  "scripts": {
    "build": "tsdown"
  },
  "private": true
}
