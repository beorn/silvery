{
  "name": "@silvery/tea",
  "version": "0.3.0",
  "description": "TEA (The Elm Architecture) state machine store for silvery",
  "license": "MIT",
  "author": "Bjørn Stabell <bjorn@stabell.org>",
  "repository": {
    "type": "git",
    "url": "https://github.com/beorn/silvery.git",
    "directory": "packages/tea"
  },
  "files": [
    "src",
    "dist"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    },
    "./core": {
      "bun": "./src/core/index.ts",
      "types": "./src/core/index.ts",
      "import": "./dist/core.js"
    },
    "./store": {
      "bun": "./src/store/index.ts",
      "types": "./src/store/index.ts",
      "import": "./dist/store.js"
    },
    "./tea": {
      "bun": "./src/tea/index.ts",
      "types": "./src/tea/index.ts",
      "import": "./dist/tea.js"
    },
    "./streams": {
      "bun": "./src/streams/index.ts",
      "types": "./src/streams/index.ts",
      "import": "./dist/streams.js"
    },
    "./plugins": {
      "bun": "./src/plugins.ts",
      "types": "./src/plugins.ts",
      "import": "./dist/plugins.js"
    },
    "./create-app": {
      "bun": "./src/create-app.tsx",
      "types": "./src/create-app.tsx",
      "import": "./dist/create-app.js"
    },
    "./*": "./src/*.ts"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@silvery/ag": "workspace:*",
    "@silvery/ag-react": "workspace:*",
    "@silvery/ag-term": "workspace:*",
    "@silvery/ink": "workspace:*",
    "@silvery/test": "workspace:*"
  }
}
