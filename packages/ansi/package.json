{
  "name": "@silvery/ansi",
  "version": "0.21.0",
  "description": "Everything terminal — styling, ANSI primitives, color detection, theme derivation, terminal control",
  "keywords": [
    "ansi",
    "chalk",
    "color",
    "detection",
    "no-color",
    "sgr",
    "style",
    "terminal",
    "theme"
  ],
  "homepage": "https://silvery.dev",
  "bugs": {
    "url": "https://github.com/beorn/silvery/issues"
  },
  "license": "MIT",
  "author": "Bjørn Stabell <bjorn@stabell.org>",
  "repository": {
    "type": "git",
    "url": "https://github.com/beorn/silvery.git",
    "directory": "packages/ansi"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.mts",
        "import": "./dist/index.mjs"
      }
    }
  },
  "scripts": {
    "build": "tsdown"
  },
  "dependencies": {
    "@silvery/color": "0.21.0",
    "string-width": "^8.2.0"
  },
  "tsdown": {
    "clean": true,
    "dts": true,
    "entry": "src/index.ts",
    "format": "esm"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
