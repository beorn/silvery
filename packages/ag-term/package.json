{
  "name": "@silvery/ag-term",
  "version": "0.4.0",
  "description": "Terminal rendering target for silvery (internal — use silvery instead)",
  "license": "MIT",
  "author": "Bjørn Stabell <bjorn@stabell.org>",
  "repository": {
    "type": "git",
    "url": "https://github.com/beorn/silvery.git",
    "directory": "packages/ag-term"
  },
  "files": [
    "src"
  ],
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./runtime": {
      "types": "./src/runtime/index.ts",
      "import": "./src/runtime/index.ts"
    },
    "./toolbelt": {
      "types": "./src/toolbelt/index.ts",
      "import": "./src/toolbelt/index.ts"
    },
    "./pipeline": {
      "types": "./src/pipeline/index.ts",
      "import": "./src/pipeline/index.ts"
    },
    "./ansi": {
      "types": "./src/ansi/index.ts",
      "import": "./src/ansi/index.ts"
    },
    "./*": {
      "types": "./src/*.ts",
      "import": "./src/*.ts"
    }
  },
  "dependencies": {
    "@silvery/ag": "workspace:*",
    "@silvery/ag-react": "workspace:*",
    "@silvery/tea": "workspace:*",
    "@silvery/test": "workspace:*",
    "@silvery/theme": "workspace:*",
    "flexily": "github:beorn/flexily"
  },
  "private": true
}
