{
  "name": "@silvery/ag-term",
  "version": "0.5.2",
  "description": "Terminal rendering target for silvery (internal — use silvery instead)",
  "license": "MIT",
  "author": "Bjørn Stabell <bjorn@stabell.org>",
  "repository": {
    "type": "git",
    "url": "https://github.com/beorn/silvery.git",
    "directory": "packages/ag-term"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.mts",
        "import": "./dist/index.mjs"
      }
    }
  },
  "dependencies": {
    "@silvery/ag": "0.5.2",
    "@silvery/ag-react": "0.5.2",
    "@silvery/ansi": "0.3.4",
    "@silvery/create": "0.5.3",
    "@silvery/headless": "0.5.1",
    "@silvery/signals": "0.5.1",
    "@silvery/test": "0.5.3",
    "@silvery/theme": "0.5.1",
    "flexily": "github:beorn/flexily"
  },
  "tsdown": {
    "entry": "src/index.ts",
    "format": "esm",
    "dts": true,
    "clean": true
  },
  "scripts": {
    "build": "tsdown"
  },
  "private": true
}
