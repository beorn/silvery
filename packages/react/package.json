{
  "name": "@silvery/react",
  "version": "0.0.1",
  "description": "Core React reconciler and runtime for silvery",
  "license": "MIT",
  "author": "Bjørn Stabell <bjorn@stabell.org>",
  "repository": {
    "type": "git",
    "url": "https://github.com/beorn/silvery.git",
    "directory": "packages/react"
  },
  "files": [
    "src"
  ],
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./hooks": {
      "types": "./src/hooks/index.ts",
      "import": "./src/hooks/index.ts"
    },
    "./reconciler": {
      "types": "./src/reconciler/index.ts",
      "import": "./src/reconciler/index.ts"
    },
    "./reconciler/host-config": {
      "types": "./src/reconciler/host-config.ts",
      "import": "./src/reconciler/host-config.ts"
    },
    "./reconciler/nodes": {
      "types": "./src/reconciler/nodes.ts",
      "import": "./src/reconciler/nodes.ts"
    },
    "./*": {
      "types": "./src/*",
      "import": "./src/*"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  }
}
