{
  "name": "@silvery/headless",
  "version": "0.17.3",
  "description": "Pure state machines for UI components — no React, no rendering, no side effects",
  "license": "MIT",
  "author": "Bjørn Stabell <bjorn@stabell.org>",
  "repository": {
    "type": "git",
    "url": "https://github.com/beorn/silvery.git",
    "directory": "packages/headless"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.mts",
        "import": "./dist/index.mjs"
      }
    }
  },
  "peerDependencies": {
    "@silvery/ag": "0.17.3",
    "@silvery/ag-term": "0.17.3"
  },
  "peerDependenciesMeta": {
    "@silvery/ag": {
      "optional": true
    },
    "@silvery/ag-term": {
      "optional": true
    }
  },
  "tsdown": {
    "entry": "src/index.ts",
    "format": "esm",
    "dts": true,
    "clean": true
  },
  "scripts": {
    "build": "tsdown"
  },
  "private": true
}
