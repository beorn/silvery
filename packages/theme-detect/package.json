{
  "name": "@silvery/theme-detect",
  "version": "0.18.2",
  "description": "Framework-agnostic terminal color scheme detection — OSC probing + catalog fingerprinting. For any TUI/CLI that wants to adopt the user's terminal theme.",
  "keywords": [
    "ansi",
    "color",
    "color-scheme",
    "oklch",
    "osc",
    "palette",
    "terminal",
    "theme",
    "tui"
  ],
  "license": "MIT",
  "author": "Bjørn Stabell <bjorn@stabell.org>",
  "repository": {
    "type": "git",
    "url": "https://github.com/beorn/silvery.git",
    "directory": "packages/theme-detect"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.mts",
        "import": "./dist/index.mjs"
      }
    }
  },
  "scripts": {
    "build": "tsdown"
  },
  "dependencies": {
    "@silvery/ansi": "0.18.2",
    "@silvery/color": "0.18.2"
  },
  "tsdown": {
    "clean": true,
    "dts": true,
    "entry": "src/index.ts",
    "format": "esm"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
