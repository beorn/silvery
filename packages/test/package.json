{
  "name": "@silvery/test",
  "version": "0.18.2",
  "private": true,
  "description": "Testing utilities for silvery — virtual renderer, locators, assertions",
  "license": "MIT",
  "author": "Bjørn Stabell <bjorn@stabell.org>",
  "repository": {
    "type": "git",
    "url": "https://github.com/beorn/silvery.git",
    "directory": "packages/test"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "src/index.tsx",
  "types": "src/index.tsx",
  "exports": {
    ".": "./src/index.tsx",
    "./*": "./src/*.ts",
    "./*.tsx": "./src/*.tsx"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.mts",
        "import": "./dist/index.mjs"
      },
      "./auto-locator": {
        "types": "./dist/auto-locator.d.mts",
        "import": "./dist/auto-locator.mjs"
      },
      "./compare-buffers": {
        "types": "./dist/compare-buffers.d.mts",
        "import": "./dist/compare-buffers.mjs"
      },
      "./debug": {
        "types": "./dist/debug.d.mts",
        "import": "./dist/debug.mjs"
      },
      "./debug-mismatch": {
        "types": "./dist/debug-mismatch.d.mts",
        "import": "./dist/debug-mismatch.mjs"
      }
    }
  },
  "scripts": {
    "build": "tsdown"
  },
  "dependencies": {
    "@silvery/ag": "0.18.1",
    "@silvery/ag-react": "0.18.1",
    "@silvery/ag-term": "0.18.1",
    "@silvery/create": "0.18.1"
  },
  "tsdown": {
    "clean": true,
    "dts": true,
    "entry": [
      "src/index.tsx",
      "src/auto-locator.ts",
      "src/compare-buffers.ts",
      "src/debug.ts",
      "src/debug-mismatch.ts"
    ],
    "format": "esm"
  },
  "engines": {
    "bun": ">=1.0",
    "node": ">=18.0.0"
  }
}
