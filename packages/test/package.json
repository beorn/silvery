{
  "name": "@silvery/test",
  "version": "0.3.0",
  "description": "Testing utilities for silvery — virtual renderer, locators, assertions",
  "license": "MIT",
  "author": "Bjørn Stabell <bjorn@stabell.org>",
  "repository": {
    "type": "git",
    "url": "https://github.com/beorn/silvery.git",
    "directory": "packages/test"
  },
  "files": [
    "src",
    "dist"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "src/index.tsx",
  "exports": {
    ".": {
      "bun": "./src/index.tsx",
      "types": "./src/index.tsx",
      "import": "./dist/index.js"
    },
    "./*": {
      "types": "./src/*.ts",
      "import": "./src/*.ts"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@silvery/ag": "workspace:*",
    "@silvery/ag-react": "workspace:*",
    "@silvery/ag-term": "workspace:*",
    "@silvery/tea": "workspace:*"
  }
}
