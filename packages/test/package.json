{
  "name": "@silvery/test",
  "version": "0.17.3",
  "description": "Testing utilities for silvery — virtual renderer, locators, assertions",
  "license": "MIT",
  "author": "Bjørn Stabell <bjorn@stabell.org>",
  "repository": {
    "type": "git",
    "url": "https://github.com/beorn/silvery.git",
    "directory": "packages/test"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "src/index.tsx",
  "types": "src/index.tsx",
  "exports": {
    ".": "./src/index.tsx"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.mts",
        "import": "./dist/index.mjs"
      }
    }
  },
  "dependencies": {
    "@silvery/ag": "0.17.3",
    "@silvery/ag-react": "0.17.3",
    "@silvery/ag-term": "0.17.3",
    "@silvery/create": "0.17.3"
  },
  "engines": {
    "bun": ">=1.0",
    "node": ">=18.0.0"
  },
  "tsdown": {
    "entry": "src/index.tsx",
    "format": "esm",
    "dts": true,
    "clean": true
  },
  "scripts": {
    "build": "tsdown"
  }
}
