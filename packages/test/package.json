{
  "name": "@silvery/test",
  "version": "0.5.0",
  "description": "Testing utilities for silvery — virtual renderer, locators, assertions",
  "license": "MIT",
  "author": "Bjørn Stabell <bjorn@stabell.org>",
  "repository": {
    "type": "git",
    "url": "https://github.com/beorn/silvery.git",
    "directory": "packages/test"
  },
  "files": [
    "src"
  ],
  "type": "module",
  "main": "src/index.tsx",
  "types": "src/index.tsx",
  "exports": {
    ".": {
      "types": "./src/index.tsx",
      "import": "./src/index.tsx"
    },
    "./*": {
      "types": "./src/*.ts",
      "import": "./src/*.ts"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@silvery/ag": "0.5.0",
    "@silvery/ag-react": "0.5.0",
    "@silvery/ag-term": "0.5.0",
    "@silvery/create": "0.5.0"
  }
}
