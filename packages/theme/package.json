{
  "name": "@silvery/theme",
  "version": "0.4.0",
  "description": "Theming system with semantic color tokens for silvery (internal — use silvery/theme instead)",
  "license": "MIT",
  "author": "Bjørn Stabell <bjorn@stabell.org>",
  "repository": {
    "type": "git",
    "url": "https://github.com/beorn/silvery.git",
    "directory": "packages/theme"
  },
  "files": [
    "src"
  ],
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./ThemeContext": {
      "types": "./src/ThemeContext.tsx",
      "import": "./src/ThemeContext.tsx"
    },
    "./*": {
      "types": "./src/*.ts",
      "import": "./src/*.ts"
    }
  },
  "dependencies": {},
  "private": true
}
