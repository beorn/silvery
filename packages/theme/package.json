{
  "name": "@silvery/theme",
  "version": "0.19.2",
  "private": true,
  "description": "Theming system with semantic color tokens for silvery (internal — use silvery/theme instead)",
  "license": "MIT",
  "author": "Bjørn Stabell <bjorn@stabell.org>",
  "repository": {
    "type": "git",
    "url": "https://github.com/beorn/silvery.git",
    "directory": "packages/theme"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./schemes": "./src/schemes/index.ts",
    "./sterling": "./src/sterling/index.ts",
    "./*": "./src/*.ts"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.mts",
        "import": "./dist/index.mjs"
      },
      "./detect": {
        "types": "./dist/detect.d.mts",
        "import": "./dist/detect.mjs"
      },
      "./schemes": {
        "types": "./dist/schemes.d.mts",
        "import": "./dist/schemes.mjs"
      },
      "./sterling": {
        "types": "./dist/sterling/index.d.mts",
        "import": "./dist/sterling/index.mjs"
      },
      "./theme": {
        "types": "./dist/theme.d.mts",
        "import": "./dist/theme.mjs"
      }
    }
  },
  "scripts": {
    "build": "tsdown"
  },
  "dependencies": {
    "@silvery/ansi": "0.19.2",
    "@silvery/color": "0.19.2"
  },
  "tsdown": {
    "clean": true,
    "dts": true,
    "entry": [
      "src/index.ts",
      "src/detect.ts",
      "src/schemes/index.ts",
      "src/sterling/index.ts",
      "src/theme.ts"
    ],
    "format": "esm"
  }
}
