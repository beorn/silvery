{
  "name": "@silvery/scope",
  "version": "0.19.2",
  "author": "Bjørn Stabell <bjorn@stabell.org>",
  "repository": {
    "type": "git",
    "url": "https://github.com/beorn/silvery.git",
    "directory": "packages/scope"
  },
  "main": "src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "description": "Structured concurrency scopes for silvery apps — cancellation, disposal, lifecycle",
  "files": [
    "dist"
  ],
  "license": "MIT",
  "private": true,
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.mts",
        "import": "./dist/index.mjs"
      }
    }
  },
  "scripts": {
    "build": "tsdown"
  },
  "tsdown": {
    "clean": true,
    "dts": true,
    "entry": "src/index.ts",
    "format": "esm"
  },
  "type": "module",
  "types": "src/index.ts"
}
