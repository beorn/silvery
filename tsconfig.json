{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": ".",
    "paths": {
      "@silvery/*": ["./packages/*/src"],
      "@silvery/react/*": ["./packages/react/src/*"],
      "@silvery/term/*": ["./packages/term/src/*"],
      "@silvery/ansi/*": ["./packages/term/src/ansi/*"],
      "@silvery/theme/*": ["./packages/theme/src/*"],
      "@silvery/tea/*": ["./packages/tea/src/*"],
      "@silvery/ui/*": ["./packages/ui/src/*"],
      "@silvery/test/*": ["./packages/test/src/*"],
      "@silvery/ink/*": ["./packages/ink/src/*"]
    }
  },
  "include": ["src", "packages/*/src"],
  "exclude": ["node_modules", "dist"]
}
