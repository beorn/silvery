{
  "compilerOptions": {
    "target": "ES2024",
    "lib": ["ESNext", "DOM"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": ".",
    "paths": {
      "@silvery/*": ["./packages/*/src"],
      "@silvery/ag/*": ["./packages/ag/src/*"],
      "@silvery/ag-react/ui/*": ["./packages/ag-react/src/ui/*"],
      "@silvery/ag-react/*": ["./packages/ag-react/src/*"],
      "@silvery/ag-term/*": ["./packages/ag-term/src/*"],
      "@silvery/ansi/*": ["./packages/ag-term/src/ansi/*"],
      "@silvery/theme/*": ["./packages/theme/src/*"],
      "@silvery/create/*": ["./packages/create/src/*"],
      "@silvery/headless/*": ["./packages/headless/src/*"],
      "@silvery/commands/*": ["./packages/commands/src/*"],
      "@silvery/model": ["./packages/model/src/index.ts"],
      "@silvery/model/*": ["./packages/model/src/*"],
      "@silvery/scope": ["./packages/scope/src/index.ts"],
      "@silvery/scope/*": ["./packages/scope/src/*"],
      "@silvery/signals": ["./packages/signals/src/index.ts"],
      "@silvery/signals/*": ["./packages/signals/src/*"],
      "@silvery/test/*": ["./packages/test/src/*"],
      "@silvery/ink/*": ["./packages/ink/src/*"]
    }
  },
  "include": ["src", "packages/*/src", "../termless/src/**/*.d.ts"],
  "exclude": ["node_modules", "dist"]
}
