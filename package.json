{
  "name": "silvery",
  "version": "0.21.0",
  "description": "React for modern terminal apps — powerful apps, polished UIs, proudly terminal",
  "keywords": [
    "ansi",
    "chalk",
    "cli",
    "flexbox",
    "ink",
    "ink-alternative",
    "react",
    "react-renderer",
    "react-terminal",
    "rendering",
    "terminal",
    "terminal-renderer",
    "terminal-ui",
    "text-ui",
    "tui",
    "ui"
  ],
  "homepage": "https://silvery.dev",
  "bugs": {
    "url": "https://github.com/beorn/silvery/issues"
  },
  "license": "MIT",
  "author": "Bjørn Stabell <bjorn@stabell.org>",
  "repository": {
    "type": "git",
    "url": "https://github.com/beorn/silvery.git"
  },
  "workspaces": [
    "packages/*",
    "!packages/examples",
    "!examples"
  ],
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./runtime": "./src/runtime.ts",
    "./term": "./src/term.ts",
    "./theme": "./src/theme.ts",
    "./ui": "./src/ui.ts",
    "./ui/*": "./src/ui/*.ts",
    "./ink": "@silvery/ink",
    "./chalk": "@silvery/ink/chalk"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.mts",
        "import": "./dist/index.mjs"
      },
      "./runtime": {
        "types": "./dist/runtime.d.mts",
        "import": "./dist/runtime.mjs"
      },
      "./term": {
        "types": "./dist/term.d.mts",
        "import": "./dist/term.mjs"
      },
      "./theme": {
        "types": "./dist/theme.d.mts",
        "import": "./dist/theme.mjs"
      },
      "./ui": {
        "types": "./dist/ui.d.mts",
        "import": "./dist/ui.mjs"
      },
      "./ui/*": {
        "types": "./dist/ui/*.d.mts",
        "import": "./dist/ui/*.mjs"
      }
    }
  },
  "scripts": {
    "build": "tsdown",
    "build:all": "tsdown && tsdown -W -F '@silvery/ag' -F '@silvery/ag-react' -F '@silvery/ag-term' -F '@silvery/ansi' -F '@silvery/color' -F '@silvery/commander' -F '@silvery/commands' -F '@silvery/create' -F '@silvery/headless' -F '@silvery/ink' -F '@silvery/model' -F '@silvery/scope' -F '@silvery/signals' -F '@silvery/theme'",
    "test": "bunx --bun vitest run",
    "test:fast": "bunx --bun vitest run --reporter=dot",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint . && oxfmt --check . && bun scripts/lint-env-reads.ts",
    "lint:env-reads": "bun scripts/lint-env-reads.ts",
    "fix": "oxlint --fix . && oxfmt --write .",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "theme": "bun packages/theme/src/cli.ts",
    "demo": "bun examples/bin/cli.ts",
    "example:storybook": "bun examples/apps/storybook/index.tsx",
    "compat": "bun packages/ink/scripts/compat-check.ts",
    "compat:ink": "bun packages/ink/scripts/compat-check.ts ink",
    "compat:chalk": "bun packages/ink/scripts/compat-check.ts chalk",
    "verify-publishable": "bun scripts/verify-publishable.ts",
    "bench": "cd benchmarks && bun run bench",
    "bench:compare": "cd benchmarks && bun run bench:compare"
  },
  "dependencies": {
    "@chenglou/pretext": "^0.0.3",
    "@silvery/color": "0.21.0",
    "@silvery/commander": "0.21.0",
    "css-select": "^7.0.0",
    "css-what": "^8.0.0",
    "loggily": "0.6.0",
    "react-reconciler": "^0.33.0",
    "slice-ansi": "^8.0.0",
    "string-width": "^8.2.0"
  },
  "devDependencies": {
    "@braintree/sanitize-url": "^7.1.2",
    "@types/bun": "^1.1.0",
    "@types/react": "^19.0.0",
    "@vue/server-renderer": "^3.5.31",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "chalk": "^5.6.2",
    "cytoscape": "^3.33.2",
    "cytoscape-cose-bilkent": "^4.1.0",
    "dayjs": "^1.11.20",
    "fast-check": "^4.6.0",
    "mermaid": "^11.14.0",
    "mitata": "^1.0.34",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "playwright": "^1.58.2",
    "react": "^19.0.0",
    "rolldown": "^1.0.0-rc.15",
    "tsdown": "^0.21.7",
    "typescript": "^5.5.0",
    "vimonkey": "^0.2.0",
    "vite-plus": "^0.1.16",
    "vitepress": "^1.5.0",
    "vitepress-enrich": "^0.4.1",
    "vitepress-plugin-d2": "^1.1.0",
    "vitepress-plugin-diagrams": "^1.2.2",
    "vitepress-plugin-llms": "^1.0.0",
    "vitepress-plugin-mermaid": "^2.0.17",
    "vitest": "^4.0.18",
    "vue": "^3.5.31",
    "yoga-wasm-web": "^0.3.3"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "tsdown": {
    "clean": true,
    "dts": true,
    "entry": [
      "src/index.ts",
      "src/runtime.ts",
      "src/term.ts",
      "src/theme.ts",
      "src/ui.ts",
      "src/ui/*.ts"
    ],
    "format": "esm"
  },
  "engines": {
    "bun": ">=1.0",
    "node": ">=18.0.0"
  }
}
