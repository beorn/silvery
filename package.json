{
  "name": "silvery",
  "version": "0.15.0",
  "description": "React for modern terminal apps — powerful apps, polished UIs, proudly terminal",
  "keywords": [
    "ansi",
    "chalk",
    "cli",
    "flexbox",
    "ink",
    "ink-alternative",
    "react",
    "react-renderer",
    "react-terminal",
    "rendering",
    "terminal",
    "terminal-renderer",
    "terminal-ui",
    "text-ui",
    "tui",
    "ui"
  ],
  "homepage": "https://silvery.dev",
  "bugs": {
    "url": "https://github.com/beorn/silvery/issues"
  },
  "license": "MIT",
  "author": "Bjørn Stabell <bjorn@stabell.org>",
  "repository": {
    "type": "git",
    "url": "https://github.com/beorn/silvery.git"
  },
  "bin": {
    "silvery": "./bin/silvery.ts"
  },
  "workspaces": [
    "packages/*",
    "!packages/examples",
    "!examples"
  ],
  "files": [
    "bin",
    "dist/**/*.js",
    "src",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "type": "module",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "import": "./src/index.ts",
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./runtime": {
      "bun": "./src/runtime.ts",
      "import": "./src/runtime.ts",
      "types": "./src/runtime.ts",
      "default": "./dist/runtime.js"
    },
    "./theme": {
      "bun": "./src/theme.ts",
      "import": "./src/theme.ts",
      "types": "./src/theme.ts",
      "default": "./dist/theme.js"
    },
    "./ui": {
      "bun": "./src/ui.ts",
      "import": "./src/ui.ts",
      "types": "./src/ui.ts",
      "default": "./dist/ui.js"
    },
    "./ui/cli": {
      "bun": "./src/ui/cli.ts",
      "import": "./src/ui/cli.ts",
      "types": "./src/ui/cli.ts",
      "default": "./dist/ui/cli.js"
    },
    "./ui/react": {
      "bun": "./src/ui/react.ts",
      "import": "./src/ui/react.ts",
      "types": "./src/ui/react.ts",
      "default": "./dist/ui/react.js"
    },
    "./ui/progress": {
      "bun": "./src/ui/progress.ts",
      "import": "./src/ui/progress.ts",
      "types": "./src/ui/progress.ts",
      "default": "./dist/ui/progress.js"
    },
    "./ui/wrappers": {
      "bun": "./src/ui/wrappers.ts",
      "import": "./src/ui/wrappers.ts",
      "types": "./src/ui/wrappers.ts",
      "default": "./dist/ui/wrappers.js"
    },
    "./ui/ansi": {
      "bun": "./src/ui/ansi.ts",
      "import": "./src/ui/ansi.ts",
      "types": "./src/ui/ansi.ts",
      "default": "./dist/ui/ansi.js"
    },
    "./ui/display": {
      "bun": "./src/ui/display.ts",
      "import": "./src/ui/display.ts",
      "types": "./src/ui/display.ts",
      "default": "./dist/ui/display.js"
    },
    "./ui/input": {
      "bun": "./src/ui/input.ts",
      "import": "./src/ui/input.ts",
      "types": "./src/ui/input.ts",
      "default": "./dist/ui/input.js"
    },
    "./ui/animation": {
      "bun": "./src/ui/animation.ts",
      "import": "./src/ui/animation.ts",
      "types": "./src/ui/animation.ts",
      "default": "./dist/ui/animation.js"
    },
    "./ui/image": {
      "bun": "./src/ui/image.ts",
      "import": "./src/ui/image.ts",
      "types": "./src/ui/image.ts",
      "default": "./dist/ui/image.js"
    },
    "./ui/utils": {
      "bun": "./src/ui/utils.ts",
      "import": "./src/ui/utils.ts",
      "types": "./src/ui/utils.ts",
      "default": "./dist/ui/utils.js"
    },
    "./ink": "@silvery/ink",
    "./chalk": "@silvery/ink/chalk"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "bun run scripts/build.ts",
    "prepublishOnly": "bun run scripts/build.ts",
    "test": "bunx --bun vitest run",
    "test:fast": "bunx --bun vitest run --reporter=dot",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint . && oxfmt --check .",
    "fix": "oxlint --fix . && oxfmt --write .",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "theme": "bun packages/theme/src/cli.ts",
    "demo": "bun examples/bin/cli.ts",
    "compat": "bun packages/ink/scripts/compat-check.ts",
    "compat:ink": "bun packages/ink/scripts/compat-check.ts ink",
    "compat:chalk": "bun packages/ink/scripts/compat-check.ts chalk",
    "bench": "cd benchmarks && bun run bench",
    "bench:compare": "cd benchmarks && bun run bench:compare"
  },
  "dependencies": {
    "@chenglou/pretext": "^0.0.3",
    "@silvery/commander": "0.8.1",
    "css-select": "^7.0.0",
    "css-what": "^8.0.0",
    "loggily": "github:beorn/loggily",
    "react-reconciler": "^0.33.0",
    "slice-ansi": "^8.0.0",
    "string-width": "^8.2.0"
  },
  "devDependencies": {
    "@types/bun": "^1.1.0",
    "@types/react": "^19.0.0",
    "@vue/server-renderer": "^3.5.31",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "chalk": "^5.6.2",
    "fast-check": "^4.6.0",
    "mermaid": "^11.14.0",
    "mitata": "^1.0.34",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "playwright": "^1.58.2",
    "react": "^19.0.0",
    "typescript": "^5.5.0",
    "vimonkey": "^0.2.0",
    "vitepress": "^1.5.0",
    "vitepress-enrich": "^0.4.1",
    "vitepress-plugin-d2": "^1.1.0",
    "vitepress-plugin-diagrams": "^1.2.2",
    "vitepress-plugin-llms": "^1.0.0",
    "vitepress-plugin-mermaid": "^2.0.17",
    "vitest": "^4.0.18",
    "vue": "^3.5.31",
    "yoga-wasm-web": "^0.3.3"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "engines": {
    "bun": ">=1.0",
    "node": ">=23.6.0"
  }
}
