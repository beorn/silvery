{
  "name": "inkx",
  "version": "0.0.1",
  "description": "Next-gen terminal UI renderer with layout feedback - Ink-compatible",
  "type": "module",
  "module": "src/index.ts",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./testing": {
      "types": "./src/testing/index.tsx",
      "import": "./src/testing/index.tsx"
    },
    "./runtime": {
      "types": "./src/runtime/index.ts",
      "import": "./src/runtime/index.ts"
    },
    "./canvas": {
      "types": "./src/canvas/index.ts",
      "import": "./src/canvas/index.ts"
    },
    "./dom": {
      "types": "./src/dom/index.ts",
      "import": "./src/dom/index.ts"
    }
  },
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target node",
    "test": "bun test tests/",
    "test:fast": "bun test tests/ --timeout 5000",
    "test:compat": "bun test tests/compat/",
    "test:visual": "playwright test",
    "test:visual:update": "playwright test --update-snapshots",
    "bench": "bun run benchmarks/index.ts",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src tests",
    "fix": "biome check --write src tests",
    "docs:dev": "vitepress dev docs/site",
    "docs:build": "vitepress build docs/site",
    "docs:preview": "vitepress preview docs/site",
    "build:web": "bun run examples/web/build.ts",
    "example:dashboard": "bun run examples/dashboard/index.tsx",
    "example:task-list": "bun run examples/task-list/index.tsx",
    "example:kanban": "bun run examples/kanban/index.tsx",
    "example:scroll": "bun run examples/scroll/index.tsx"
  },
  "keywords": [
    "terminal",
    "tui",
    "cli",
    "react",
    "ink",
    "flexbox",
    "layout"
  ],
  "author": "beorn",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/beorn/inkx.git"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "@beorn/flexx": "github:beorn/flexx",
    "yoga-wasm-web": "^0.3.3"
  },
  "peerDependenciesMeta": {
    "@beorn/flexx": {
      "optional": true
    },
    "yoga-wasm-web": {
      "optional": true
    }
  },
  "dependencies": {
    "chalkx": "github:beorn/chalkx",
    "graphemer": "^1.4.0",
    "react-reconciler": "^0.33.0",
    "slice-ansi": "^7.1.2",
    "string-width": "^8.0.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@beorn/flexx": "github:beorn/flexx",
    "@biomejs/biome": "^1.9.0",
    "@types/bun": "^1.1.0",
    "@types/react": "^19.0.0",
    "chalk": "^5.6.2",
    "fast-check": "^4.5.3",
    "mitata": "^0.1.11",
    "react": "^19.0.0",
    "typescript": "^5.5.0",
    "vitepress": "^1.5.0",
    "vitepress-plugin-llms": "^1.0.0",
    "yoga-wasm-web": "^0.3.3"
  }
}
