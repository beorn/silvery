{
  "name": "silvery",
  "version": "0.0.1",
  "description": "Multi-target rendering framework for React — terminal, browser, and beyond",
  "keywords": [
    "chalk",
    "cli",
    "ink",
    "react",
    "rendering",
    "terminal",
    "tui",
    "ui"
  ],
  "homepage": "https://silvery.dev",
  "bugs": {
    "url": "https://github.com/beorn/silvery/issues"
  },
  "license": "MIT",
  "author": "Bjørn Stabell <bjorn@stabell.org>",
  "repository": {
    "type": "git",
    "url": "https://github.com/beorn/silvery.git"
  },
  "workspaces": [
    "packages/*"
  ],
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./ink": {
      "types": "./packages/compat/src/ink.ts",
      "import": "./packages/compat/src/ink.ts"
    },
    "./chalk": {
      "types": "./packages/compat/src/chalk.ts",
      "import": "./packages/compat/src/chalk.ts"
    }
  },
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target node",
    "test": "bunx --bun vitest run",
    "test:fast": "bunx --bun vitest run --reporter=dot",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint . && oxfmt --check .",
    "fix": "oxlint --fix . && oxfmt --write .",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "changeset publish"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "decant": "github:beorn/decant",
    "loggily": "^0.0.1",
    "react-reconciler": "^0.33.0",
    "slice-ansi": "^8.0.0",
    "string-width": "^8.2.0",
    "swatch": "github:beorn/swatch",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "@types/bun": "^1.1.0",
    "@types/react": "^19.0.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "fast-check": "^4.6.0",
    "mitata": "^1.0.34",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "playwright": "^1.58.2",
    "react": "^19.0.0",
    "typescript": "^5.5.0",
    "vitest": "^4.0.18",
    "yoga-wasm-web": "^0.3.3"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "engines": {
    "bun": ">=1.0",
    "node": ">=18"
  }
}
