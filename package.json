{
  "name": "silvery",
  "version": "0.10.0",
  "description": "React terminal UI renderer for complex interactive apps — layout-aware rendering, flexbox, scrolling, and incremental updates",
  "keywords": [
    "ansi",
    "chalk",
    "cli",
    "flexbox",
    "ink",
    "ink-alternative",
    "react",
    "react-renderer",
    "react-terminal",
    "rendering",
    "terminal",
    "terminal-renderer",
    "terminal-ui",
    "text-ui",
    "tui",
    "ui"
  ],
  "homepage": "https://silvery.dev",
  "bugs": {
    "url": "https://github.com/beorn/silvery/issues"
  },
  "license": "MIT",
  "author": "Bjørn Stabell <bjorn@stabell.org>",
  "repository": {
    "type": "git",
    "url": "https://github.com/beorn/silvery.git"
  },
  "workspaces": [
    "packages/*",
    "!packages/examples"
  ],
  "files": [
    "src"
  ],
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./runtime": "./src/runtime.ts",
    "./theme": "./src/theme.ts",
    "./ui": "./src/ui.ts",
    "./ui/cli": "./src/ui/cli.ts",
    "./ui/react": "./src/ui/react.ts",
    "./ui/progress": "./src/ui/progress.ts",
    "./ui/wrappers": "./src/ui/wrappers.ts",
    "./ui/ansi": "./src/ui/ansi.ts",
    "./ui/display": "./src/ui/display.ts",
    "./ui/input": "./src/ui/input.ts",
    "./ui/animation": "./src/ui/animation.ts",
    "./ui/image": "./src/ui/image.ts",
    "./ui/utils": "./src/ui/utils.ts",
    "./ink": "@silvery/ink",
    "./chalk": "@silvery/ink/chalk"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "bun run scripts/build.ts",
    "test": "bunx --bun vitest run",
    "test:fast": "bunx --bun vitest run --reporter=dot",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint . && oxfmt --check .",
    "fix": "oxlint --fix . && oxfmt --write .",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "theme": "bun packages/theme/src/cli.ts",
    "demo": "bun examples/cli.ts",
    "compat": "bun packages/ink/scripts/compat-check.ts",
    "compat:ink": "bun packages/ink/scripts/compat-check.ts ink",
    "compat:chalk": "bun packages/ink/scripts/compat-check.ts chalk"
  },
  "dependencies": {
    "@chenglou/pretext": "^0.0.3",
    "@silvery/commander": "workspace:*",
    "loggily": "github:beorn/loggily",
    "react-reconciler": "^0.33.0",
    "slice-ansi": "^8.0.0",
    "string-width": "^8.2.0"
  },
  "devDependencies": {
    "@types/bun": "^1.1.0",
    "@types/react": "^19.0.0",
    "@vue/server-renderer": "^3.5.31",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "chalk": "^5.6.2",
    "fast-check": "^4.6.0",
    "mermaid": "^11.14.0",
    "mitata": "^1.0.34",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.51.0",
    "playwright": "^1.58.2",
    "react": "^19.0.0",
    "typescript": "^5.5.0",
    "vimonkey": "^0.2.0",
    "vitepress": "^1.5.0",
    "vitepress-enrich": "^0.4.0",
    "vitepress-plugin-d2": "^1.1.0",
    "vitepress-plugin-diagrams": "^1.2.2",
    "vitepress-plugin-llms": "^1.0.0",
    "vitepress-plugin-mermaid": "^2.0.17",
    "vitest": "^4.0.18",
    "vue": "^3.5.31",
    "yoga-wasm-web": "^0.3.3"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "engines": {
    "bun": ">=1.0",
    "node": ">=23.6.0"
  }
}
